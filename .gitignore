# ==============================================================================
# MESA Memory Layer - .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Python & Build Artifacts
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
env/
venv/
build/
dist/
*.egg-info/
*.egg
*.whl
pip-wheel-metadata/
.coverage
.coverage.*
coverage.xml
htmlcov/
bench_results.json
.benchmarks/
.tox/
.nox/

# ------------------------------------------------------------------------------
# 2. MESA Databases & Vector Storage (Zero Trust / Critical)
#    Strictly ignore all clinical data, embeddings, and raw transaction logs.
# ------------------------------------------------------------------------------
# Relational & Graph DBs
*.db
*.sqlite3
raw_log.db
storage/*.db
storage/*.sqlite3
storage/*.jsonl

# RocksDB
*.rocksdb
rocksdict_archive/
storage/*.rocks

# Vector Storage (LanceDB)
*.lance
storage/*.lance
storage/**/*.lance
vector_index.lance
storage/vector_index*/

# RBAC Policy DB (auto-generated, not source-controlled)
storage/rbac_policy.db

# ------------------------------------------------------------------------------
# 3. Environment Variables & Secrets
#    Never commit API keys (OpenAI, Anthropic, Groq) or local config overrides.
# ------------------------------------------------------------------------------
.env
.env.local
.env.test
.env.*
!.env.example

# ------------------------------------------------------------------------------
# 4. Model Caches & Large Binaries
#    REBEL / HuggingFace transformer weights should never enter the repo.
# ------------------------------------------------------------------------------
models/
huggingface_cache/
*.bin
*.pt
*.onnx
*.safetensors
.cache/

# ------------------------------------------------------------------------------
# 5. OS & IDE Configuration
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# 6. Logs & Temporary Files
# ------------------------------------------------------------------------------
*.log
tmp/
temp/
scratch/
scratch*.py
test_minimal*.py
storage_bench_tmp/
eval_results.json
sweep_results.json
*.jsonl

# ------------------------------------------------------------------------------
# 7. Jupyter Notebook Checkpoints
# ------------------------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# 8. Agent / Tooling Metadata
# ------------------------------------------------------------------------------
.gemini/
.audit/

# ------------------------------------------------------------------------------
# 9. Data Pipelines
#    Ignore all data except the whitelisted raw dataset.
# ------------------------------------------------------------------------------
data/*
!data/raw/
data/raw/*
!data/raw/ma_dataset.json

# Test storage directories (dynamically created by conftest.py)
.test_storage_tmp/
*.sqlite

# ------------------------------------------------------------------------------
# 10. Ephemeral Benchmark & Evaluation Artifacts
#     Generated by mesa_evals, pytest-benchmark, and load-test scripts.
#     Never commit these — they are machine-specific and non-reproducible.
# ------------------------------------------------------------------------------
bench_*.sqlite
bench_*.db
legal_golden.json
soak_test_*.jsonl
temp_*.py
temp_*.md
.coverage
.coverage.*

# KuzuDB Storage Files
storage/kuzu_db*
storage/*.kuzu

# Test Databases
test_db/
test_db_*/
*.db
*.lance/
.kuzu/
.ci_storage_test/
test_db
test_db_2
test_db_3
test_kuzu_db
storage/*/

# ------------------------------------------------------------------------------
# 11. Added via surgical cleanup
# ------------------------------------------------------------------------------
*.bak
mutants/
.env
storage/
*.db
__pycache__/

# Ephemeral benchmark execution artifacts
/results/
mesa-benchmark/results/
report_*.md
reproducibility_report.json
state.json
colab_sonuc.md
_temp_config.yaml
beam_eval_report.json
rewrite_harness.py
test_node.py
test_qdrant/
# External/generated payloads are reproduced by `mesa-benchmark dataset-sync`.
mesa-benchmark/datasets/external/beam/v2/dataset.json
mesa-benchmark/datasets/external/locomo/dataset.json
mesa-benchmark/datasets/external/longmemeval/dataset.json
mesa-benchmark/datasets/external/memoryagentbench/dataset.json
mesa-benchmark/datasets/external/memoryagentbench/recsys.json
mesa-benchmark/datasets/generated/beam/scale/*.json
mesa-benchmark/datasets/generated/beam/ablations/*.json
mesa-benchmark/datasets/external_raw/
