# ==============================================================================
# MESA Memory Layer - .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Python & Build Artifacts
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
env/
venv/
build/
dist/
*.egg-info/
.coverage
htmlcov/
.tox/

# ------------------------------------------------------------------------------
# 2. MESA Databases & Vector Storage (Zero Trust / Critical)
#    Strictly ignore all clinical data, embeddings, and raw transaction logs.
# ------------------------------------------------------------------------------
# Relational & Graph DBs
*.db
*.sqlite3
raw_log.db
storage/*.db
storage/*.sqlite3
*.rocksdb
rocksdict_archive/
storage/*.rocks

# Vector Storage (LanceDB)
*.lance
storage/*.lance
vector_index.lance

# ------------------------------------------------------------------------------
# 3. Environment Variables & Secrets
#    Never commit API keys (OpenAI, Anthropic) or local config overrides.
# ------------------------------------------------------------------------------
.env
.env.local
.env.test
.env.*

# ------------------------------------------------------------------------------
# 4. OS & IDE Configuration
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# 5. Logs & Temporary Files
# ------------------------------------------------------------------------------
*.log
tmp/
temp/


# Temporary debug scripts
run_*.py
fix_*.py