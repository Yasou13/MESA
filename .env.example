MESA_LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL_NAME=llama-3.1-8b-instant

MESA_API_KEY=your_production_api_key_here

# REBEL model: disabled by default (LLM zero-shot extraction is the primary path)
# Set to true ONLY in GPU-equipped environments for English-only workloads
MESA_REBEL_ENABLED=false

# Extraction language: "tr" (Turkish legal/formal) or "en" (English general)
MESA_EXTRACTION_LANG=tr

# Resilience & Retry (Phase 2.3)
MESA_RETRY_MAX_ATTEMPTS=5
MESA_RETRY_MIN_WAIT_SEC=2
MESA_RETRY_MAX_WAIT_SEC=60
MESA_CIRCUIT_BREAKER_THRESHOLD=10
MESA_CIRCUIT_BREAKER_COOLDOWN=60.0

# Internal Tuning Parameters
MESA_HYBRID_ALPHA=0.5
MESA_HYBRID_BETA=0.5
MESA_T_ROUTE=0.85
MESA_LEGAL_DOMAIN_MODE=false
MESA_MAX_RAM_MB=2048

# Zero-Cost Mode (v0.5.1)
# Set to true to route ALL inference to local Ollama — zero API costs.
# Requires: ollama serve running, model pulled (e.g. ollama pull llama3.2:3b)
MESA_ZERO_COST_MODE=false
MESA_OLLAMA_URL=http://localhost:11434
