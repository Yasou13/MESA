# Copy explicitly and load only via MESA_DOTENV_PATH when policy permits.
# Production values must come from the deployment secret manager.
MESA_RUNTIME_PROFILE=api-only
MESA_STORAGE_ROOT=/var/lib/mesa/data
MESA_LOAD_DOTENV=false
MESA_MODEL_ENABLED=false
MESA_EXTERNAL_PROVIDER_ENABLED=false
MESA_API_KEY=replace-with-secret-manager-reference
MESA_PRINCIPAL_ID=replace-with-server-side-principal
MESA_PRINCIPAL_TYPE=SERVICE
MESA_PRINCIPAL_STATUS=active
MESA_PORT=8000

# Queue admission remains bounded. Override only through reviewed deployment config.
MESA_QUEUE_MAX_PENDING_RECORDS=10000
MESA_QUEUE_MAX_PENDING_BYTES=536870912
MESA_QUEUE_MAX_IN_FLIGHT_RECORDS=32
