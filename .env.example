# This is a standalone runtime template. Compose supplies role, storage and
# model/provider flags itself; pass MESA_API_KEY and MESA_PRINCIPAL_ID via a
# secret manager or exported environment variables instead of committing `.env`.
# Copy explicitly and load only via MESA_DOTENV_PATH when policy permits.
MESA_RUNTIME_PROFILE=api-only
MESA_STORAGE_ROOT=/var/lib/mesa/data
MESA_LOAD_DOTENV=false
MESA_MODEL_ENABLED=false
MESA_EXTERNAL_PROVIDER_ENABLED=false
MESA_API_KEY=replace-with-secret-manager-reference
MESA_PRINCIPAL_ID=replace-with-server-side-principal
MESA_PRINCIPAL_TYPE=SERVICE
MESA_PRINCIPAL_STATUS=active
MESA_PORT=8000

# V4 uses one combined storage owner. Catalog memberships and agent/dataset
# grants are provisioned with `mesa-v4-admin`; they are not inferred from
# request fields or automatically granted from these environment variables.
# MESA_RUNTIME_PROFILE=combined
# MESA_MODEL_ENABLED=true
# MESA_EXTERNAL_PROVIDER_ENABLED=true
# MESA_TENANT_ID=tenant-a
# MESA_WORKSPACE_ID=workspace-a
# MESA_DATASET_IDS=dataset-a
# MESA_AGENT_ID=agent-a

# Queue admission remains bounded. Override only through reviewed deployment config.
MESA_QUEUE_MAX_PENDING_RECORDS=10000
MESA_QUEUE_MAX_PENDING_BYTES=536870912
MESA_QUEUE_MAX_IN_FLIGHT_RECORDS=32

# Local MESA MCP client (stdio).  Keep MESA_API_KEY out of this template.
# MESA_BASE_URL=http://localhost:8000
# MESA_NAMESPACE=local
# MESA_PROJECT_ID=mesa
# MESA_ACTOR_ID=antigravity-agent
# MESA_WORKSPACE_ROOT=/absolute/path/to/MESA
# MESA_SEARCH_DEFAULT_LIMIT=8
# MESA_SEARCH_MAX_LIMIT=20
# MESA_CONTEXT_DEFAULT_TOKEN_BUDGET=2500
# MESA_CONTEXT_MAX_TOKEN_BUDGET=8000
